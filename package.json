{
  "name": "oh-my-pr",
  "version": "1.0.0",
  "description": "Autonomous GitHub PR babysitter that watches repos, triages review feedback, and dispatches AI agents to fix code locally",
  "keywords": [
    "github",
    "pull-request",
    "code-review",
    "ai-agent",
    "claude",
    "codex",
    "automation",
    "developer-tools",
    "pr-management",
    "babysitter"
  ],
  "homepage": "https://github.com/yungookim/oh-my-pr#readme",
  "bugs": {
    "url": "https://github.com/yungookim/oh-my-pr/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yungookim/oh-my-pr.git"
  },
  "license": "MIT",
  "author": "dygk",
  "type": "module",
  "main": "dist/index.cjs",
  "bin": {
    "oh-my-pr": "bin/codefactory.cjs"
  },
  "directories": {
    "doc": "docs"
  },
  "files": [
    "dist/",
    "bin/"
  ],
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "tsx script/build.ts",
    "prepublishOnly": "npm run build",
    "build:docs": "mkdir -p docs/assets && tailwindcss -c docs/tailwind.config.cjs -i docs/src/input.css -o docs/assets/landing.css --minify",
    "build:public-docs": "tsx script/build-public-docs.ts",
    "start": "NODE_ENV=production node dist/index.cjs",
    "mcp": "tsx server/mcp.ts",
    "lint": "eslint .",
    "test": "node --import tsx --test server/*.test.ts",
    "check": "tsc",
    "db:push": "drizzle-kit push",
    "tauri:dev": "TAURI_DEV=1 tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
